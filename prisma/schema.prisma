// Reference schema only.
// Runtime persistence in this project uses direct SQL via `pg` (see lib/database.ts).
// Prisma is intentionally not used for this deployment.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id          BigInt   @id @default(autoincrement())
  accountId   String
  shopDomain  String
  accessToken String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([accountId, shopDomain])
}

model AppSubscription {
  id               BigInt   @id @default(autoincrement())
  storeId          BigInt
  appGid           String
  appName          String
  monthlyUsd       Decimal
  currencyCode     String
  previousMonthlyUsd Decimal?
  category         String
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([storeId, appGid])
}
